# ORIS Dev Employee read-only Web Console local config
# Copy this file to .env on the server and edit values there.
# .env is ignored by git and must not be committed.
# Official domain base: orisfy.com
# Console route: control.orisfy.com

ORIS_NGINX_READONLY_CONSOLE_SERVER_NAME=control.orisfy.com
ORIS_NGINX_READONLY_CONSOLE_HTPASSWD_FILE=/etc/nginx/oris-dev-employee.htpasswd
ORIS_NGINX_READONLY_CONSOLE_TLS_CERT=/etc/letsencrypt/live/control.orisfy.com/fullchain.pem
ORIS_NGINX_READONLY_CONSOLE_TLS_KEY=/etc/letsencrypt/live/control.orisfy.com/privkey.pem
ORIS_NGINX_READONLY_CONSOLE_CANDIDATE=/tmp/oris-dev-employee-web-console.readonly.conf
