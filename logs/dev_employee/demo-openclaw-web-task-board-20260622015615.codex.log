        "title": "Write tests",
        "description": "Cover API",
        "status": "todo",
        "assignee": "dev",
        "tags": [],
    }
    assert client.get("/tasks").json() == [response.json()]


def test_list_tasks_filters_by_status() -> None:
    todo = client.post("/tasks", json={"title": "Plan", "status": "todo"}).json()
    client.post("/tasks", json={"title": "Build", "status": "doing"})
    done = client.post("/tasks", json={"title": "Ship", "status": "done"}).json()

    assert client.get("/tasks", params={"status": "todo"}).json() == [todo]
    assert client.get("/tasks", params={"status": "done"}).json() == [done]


def test_list_tasks_filters_by_assignee() -> None:
    dev_task = client.post(
        "/tasks",
        json={"title": "Build", "assignee": "dev"},
    ).json()
    client.post("/tasks", json={"title": "Review", "assignee": "lead"})
    unassigned = client.post("/tasks", json={"title": "Backlog"}).json()

    assert client.get("/tasks", params={"assignee": "dev"}).json() == [dev_task]
    assert client.get("/tasks", params={"assignee": "lead"}).json()[0]["title"] == "Review"
    assert unassigned not in client.get("/tasks", params={"assignee": "dev"}).json()


def test_list_tasks_filters_by_status_and_assignee() -> None:
    match = client.post(
        "/tasks",
        json={"title": "Owned done", "status": "done", "assignee": "dev"},
    ).json()
    client.post("/tasks", json={"title": "Other done", "status": "done", "assignee": "lead"})
    client.post("/tasks", json={"title": "Owned todo", "status": "todo", "assignee": "dev"})

    response = client.get("/tasks", params={"status": "done", "assignee": "dev"})

    assert response.status_code == 200
    assert response.json() == [match]


def test_list_tasks_rejects_invalid_status_filter() -> None:
    response = client.get("/tasks", params={"status": "blocked"})

    assert response.status_code == 422


def test_read_task_by_id() -> None:
    created = client.post("/tasks", json={"title": "Read me"}).json()

    response = client.get(f"/tasks/{created['id']}")

    assert response.status_code == 200
    assert response.json()["title"] == "Read me"
    assert response.json()["tags"] == []


def test_patch_task() -> None:
    created = client.post("/tasks", json={"title": "Start"}).json()

    response = client.patch(
        f"/tasks/{created['id']}",
        json={"title": "Finish", "status": "done", "assignee": None},
    )

    assert response.status_code == 200
    assert response.json() == {
        "id": created["id"],
        "title": "Finish",
        "description": "",
        "status": "done",
        "assignee": None,
        "tags": [],
    }


def test_create_and_read_task_with_tags() -> None:
    response = client.post(
        "/tasks",
        json={"title": "Tag me", "tags": ["api", "acceptance"]},
    )

    assert response.status_code == 201
    assert response.json()["tags"] == ["api", "acceptance"]
    assert client.get("/tasks").json()[0]["tags"] == ["api", "acceptance"]
    assert client.get("/tasks/1").json()["tags"] == ["api", "acceptance"]


def test_patch_task_tags() -> None:
    created = client.post("/tasks", json={"title": "Start", "tags": ["old"]}).json()

    response = client.patch(f"/tasks/{created['id']}", json={"tags": ["new", "triaged"]})

    assert response.status_code == 200
    assert response.json()["tags"] == ["new", "triaged"]


def test_delete_task() -> None:
    created = client.post("/tasks", json={"title": "Remove"}).json()


