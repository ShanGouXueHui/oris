from enum import Enum
from typing import Dict, Optional

from fastapi import FastAPI, HTTPException
from pydantic import BaseModel, ConfigDict, Field


class TaskStatus(str, Enum):
    todo = "todo"
    doing = "doing"
    done = "done"


class TaskCreate(BaseModel):
    title: str = Field(..., min_length=1)
    description: str = ""
    status: TaskStatus = TaskStatus.todo
    assignee: Optional[str] = None
    tags: list[str] = Field(default_factory=list)


class TaskUpdate(BaseModel):
    model_config = ConfigDict(extra="forbid")

    title: Optional[str] = Field(default=None, min_length=1)
    description: Optional[str] = None
    status: Optional[TaskStatus] = None
    assignee: Optional[str] = None
    tags: Optional[list[str]] = None


class Task(TaskCreate):
    id: int


class TaskStats(BaseModel):
    total_tasks: int
    by_status: dict[str, int]


class Capabilities(BaseModel):
    service: str
    storage: str
    features: dict[str, bool]


class HealthDetails(BaseModel):
    service_name: str
    version: str
    storage_mode: str
    task_count: int


SERVICE_NAME = "ORIS Final Acceptance API"
SERVICE_VERSION = "1.0.0"
STORAGE_MODE = "in-memory"

app = FastAPI(title="ORIS Final Acceptance API")

tasks: Dict[int, Task] = {}
next_task_id = 1


@app.get("/health")
async def health() -> dict[str, str]:
    return {"status": "ok"}


@app.get("/healthz")
async def healthz() -> dict[str, str]:
    return {"status": "ok"}


@app.get("/healthz/details", response_model=HealthDetails)
async def healthz_details() -> HealthDetails:
    return HealthDetails(
        service_name=SERVICE_NAME,
        version=SERVICE_VERSION,
        storage_mode=STORAGE_MODE,
        task_count=len(tasks),
    )


@app.get("/readyz")
async def readyz() -> dict[str, bool]:
    return {"ready": True}


@app.get("/livez")
async def livez() -> dict[str, bool]:
    return {"live": True}


@app.get("/consolez")
async def consolez() -> dict[str, bool]:
    return {"console": True}


@app.get("/ping")
async def ping() -> dict[str, bool]:
    return {"pong": True}


@app.get("/readonly-e2e")
async def readonly_e2e() -> dict[str, bool]:
    return {"readonly_e2e": True}


@app.get("/version")
async def version() -> dict[str, str]:
    return {"version": SERVICE_VERSION}


@app.get("/info")
async def info() -> dict[str, object]:
    return {
        "app_name": SERVICE_NAME,
        "version": SERVICE_VERSION,
        "storage": STORAGE_MODE,
        "endpoints": ["health", "healthz", "stats", "tasks"],
    }


@app.get("/capabilities", response_model=Capabilities)
async def capabilities() -> Capabilities:
    return Capabilities(
        service=SERVICE_NAME,
        storage=STORAGE_MODE,
        features={
            "task_crud": True,
            "filtering": True,
            "stats": True,
        },
    )


@app.get("/stats", response_model=TaskStats)
async def get_stats() -> TaskStats:
    by_status = {status.value: 0 for status in TaskStatus}
    for task in tasks.values():
        by_status[task.status.value] += 1
    return TaskStats(total_tasks=len(tasks), by_status=by_status)


@app.get("/tasks", response_model=list[Task])
async def list_tasks(
    status: Optional[TaskStatus] = None,
    assignee: Optional[str] = None,
) -> list[Task]:
    task_list = list(tasks.values())
    if status is not None:
        task_list = [task for task in task_list if task.status == status]
    if assignee is not None:
        task_list = [task for task in task_list if task.assignee == assignee]
    return task_list


@app.post("/tasks", response_model=Task, status_code=201)
async def create_task(task: TaskCreate) -> Task:
    global next_task_id

    created = Task(id=next_task_id, **task.model_dump())
    tasks[created.id] = created
    next_task_id += 1
    return created


@app.get("/tasks/{task_id}", response_model=Task)
async def get_task(task_id: int) -> Task:
    task = tasks.get(task_id)
    if task is None:
        raise HTTPException(status_code=404, detail="Task not found")
    return task


@app.patch("/tasks/{task_id}", response_model=Task)
async def update_task(task_id: int, patch: TaskUpdate) -> Task:
    task = tasks.get(task_id)
    if task is None:
        raise HTTPException(status_code=404, detail="Task not found")

    updated_data = task.model_dump()
    updated_data.update(patch.model_dump(exclude_unset=True))
    updated = Task(**updated_data)
    tasks[task_id] = updated
    return updated


@app.delete("/tasks/{task_id}")
async def delete_task(task_id: int) -> dict[str, object]:
    if task_id not in tasks:
        raise HTTPException(status_code=404, detail="Task not found")

    del tasks[task_id]
    return {"deleted": True, "id": task_id}

