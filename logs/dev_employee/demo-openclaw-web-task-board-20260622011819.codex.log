from fastapi.testclient import TestClient

from app.main import app, tasks


client = TestClient(app)


def setup_function() -> None:
    tasks.clear()
    import app.main as main

    main.next_task_id = 1


def test_health() -> None:
    response = client.get("/health")

    assert response.status_code == 200
    assert response.json() == {"status": "ok"}


def test_healthz_details_returns_service_metadata_for_empty_board() -> None:
    response = client.get("/healthz/details")

    assert response.status_code == 200
    assert response.json() == {
        "service_name": "ORIS Final Acceptance API",
        "version": "1.0.0",
        "storage_mode": "in-memory",
        "task_count": 0,
    }


def test_healthz_details_counts_current_tasks() -> None:
    client.post("/tasks", json={"title": "Plan"})
    client.post("/tasks", json={"title": "Build"})

    response = client.get("/healthz/details")

    assert response.status_code == 200
    assert response.json()["task_count"] == 2


def test_readyz_returns_ready_true() -> None:
    response = client.get("/readyz")

    assert response.status_code == 200
    assert response.json() == {"ready": True}


def test_livez_returns_exact_live_true() -> None:
    response = client.get("/livez")

    assert response.status_code == 200
    assert response.json() == {"live": True}


def test_consolez_returns_exact_console_true() -> None:
    response = client.get("/consolez")

    assert response.status_code == 200
    assert response.json() == {"console": True}


def test_ping_returns_exact_pong_true() -> None:
    response = client.get("/ping")

    assert response.status_code == 200
    assert response.json() == {"pong": True}


def test_readonly_e2e_returns_exact_true() -> None:
    response = client.get("/readonly-e2e")

    assert response.status_code == 200
    assert response.json() == {"readonly_e2e": True}


def test_info_returns_stable_api_metadata() -> None:
    response = client.get("/info")

    assert response.status_code == 200
    assert response.json() == {
        "app_name": "ORIS Final Acceptance API",
        "version": "1.0.0",
        "storage": "in-memory",
        "endpoints": ["health", "healthz", "stats", "tasks"],
    }


def test_capabilities_returns_service_storage_and_features() -> None:
    response = client.get("/capabilities")

    assert response.status_code == 200
    assert response.json() == {
        "service": "ORIS Final Acceptance API",
        "storage": "in-memory",
        "features": {
            "task_crud": True,
            "filtering": True,
            "stats": True,
        },
    }


def test_capabilities_field_contract() -> None:
    body = client.get("/capabilities").json()

    assert set(body) == {"service", "storage", "features"}
    assert isinstance(body["service"], str)
    assert isinstance(body["storage"], str)
    assert {"task_crud", "filtering", "stats"} <= set(body["features"])


def test_version_returns_exact_api_version() -> None:
    response = client.get("/version")

    assert response.status_code == 200
    assert response.json() == {"version": "1.0.0"}


def test_stats_returns_zero_counts_for_empty_board() -> None:
    response = client.get("/stats")

    assert response.status_code == 200
    assert response.json() == {
        "total_tasks": 0,
        "by_status": {"todo": 0, "doing": 0, "done": 0},
    }


def test_stats_counts_tasks_by_status() -> None:
    client.post("/tasks", json={"title": "Plan", "status": "todo"})
    doing = client.post("/tasks", json={"title": "Build", "status": "doing"}).json()
    client.post("/tasks", json={"title": "Ship", "status": "done"})
    client.patch(f"/tasks/{doing['id']}", json={"status": "done"})

    response = client.get("/stats")

    assert response.status_code == 200
    assert response.json() == {
        "total_tasks": 3,
        "by_status": {"todo": 1, "doing": 0, "done": 2},
    }


def test_create_and_list_tasks() -> None:
    response = client.post(
        "/tasks",
        json={"title": "Write tests", "description": "Cover API", "assignee": "dev"},
    )

    assert response.status_code == 201
    assert response.json() == {
        "id": 1,
        "title": "Write tests",
        "description": "Cover API",
        "status": "todo",
        "assignee": "dev",
        "tags": [],
    }
    assert client.get("/tasks").json() == [response.json()]


def test_list_tasks_filters_by_status() -> None:
    todo = client.post("/tasks", json={"title": "Plan", "status": "todo"}).json()
    client.post("/tasks", json={"title": "Build", "status": "doing"})
    done = client.post("/tasks", json={"title": "Ship", "status": "done"}).json()

    assert client.get("/tasks", params={"status": "todo"}).json() == [todo]
    assert client.get("/tasks", params={"status": "done"}).json() == [done]


def test_list_tasks_filters_by_assignee() -> None:
    dev_task = client.post(
        "/tasks",
        json={"title": "Build", "assignee": "dev"},
    ).json()
    client.post("/tasks", json={"title": "Review", "assignee": "lead"})
    unassigned = client.post("/tasks", json={"title": "Backlog"}).json()

    assert client.get("/tasks", params={"assignee": "dev"}).json() == [dev_task]
    assert client.get("/tasks", params={"assignee": "lead"}).json()[0]["title"] == "Review"
    assert unassigned not in client.get("/tasks", params={"assignee": "dev"}).json()


def test_list_tasks_filters_by_status_and_assignee() -> None:
    match = client.post(
        "/tasks",
        json={"title": "Owned done", "status": "done", "assignee": "dev"},
    ).json()
    client.post("/tasks", json={"title": "Other done", "status": "done", "assignee": "lead"})
    client.post("/tasks", json={"title": "Owned todo", "status": "todo", "assignee": "dev"})

    response = client.get("/tasks", params={"status": "done", "assignee": "dev"})

    assert response.status_code == 200
    assert response.json() == [match]


def test_list_tasks_rejects_invalid_status_filter() -> None:
    response = client.get("/tasks", params={"status": "blocked"})

    assert response.status_code == 422


def test_read_task_by_id() -> None:
    created = client.post("/tasks", json={"title": "Read me"}).json()

    response = client.get(f"/tasks/{created['id']}")

    assert response.status_code == 200
    assert response.json()["title"] == "Read me"
    assert response.json()["tags"] == []


def test_patch_task() -> None:
    created = client.post("/tasks", json={"title": "Start"}).json()

    response = client.patch(
        f"/tasks/{created['id']}",
        json={"title": "Finish", "status": "done", "assignee": None},
    )

    assert response.status_code == 200
    assert response.json() == {
        "id": created["id"],
        "title": "Finish",
        "description": "",
        "status": "done",
        "assignee": None,
        "tags": [],
    }


def test_create_and_read_task_with_tags() -> None:
    response = client.post(
        "/tasks",
        json={"title": "Tag me", "tags": ["api", "acceptance"]},
    )

    assert response.status_code == 201
    assert response.json()["tags"] == ["api", "acceptance"]
    assert client.get("/tasks").json()[0]["tags"] == ["api", "acceptance"]
    assert client.get("/tasks/1").json()["tags"] == ["api", "acceptance"]


def test_patch_task_tags() -> None:
    created = client.post("/tasks", json={"title": "Start", "tags": ["old"]}).json()

    response = client.patch(f"/tasks/{created['id']}", json={"tags": ["new", "triaged"]})

    assert response.status_code == 200
    assert response.json()["tags"] == ["new", "triaged"]


def test_delete_task() -> None:
    created = client.post("/tasks", json={"title": "Remove"}).json()


