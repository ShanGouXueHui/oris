      "local_path": "/home/admin/projects/oris",
      "default_branch": "main",
      "allowed_scope": [
        "docs/",
        "orchestration/",
        "scripts/",
        "logs/dev_employee/",
        "memory/"
      ],
      "forbidden_scope": [
        ".env",
        "secrets",
        "production_credentials"
