{
  "answer_policy": {
    "version": 1,
    "correctness_first": true,
    "evidence_required_for_key_claims": true,
    "require_data_points": true,
    "require_source_name": true,
    "require_source_link": true,
    "require_fact_inference_risk_split": true,
    "source_priority": [
      "official_primary",
      "authoritative_secondary",
      "general_secondary"
    ],
    "minimum_sources": {
      "fact_question": 1,
      "analysis_question": 2,
      "high_risk_question": 3
    },
    "disallow_unsupported_numeric_claims": true,
    "disallow_fabricated_sources": true,
    "degrade_when_sources_insufficient": true,
    "answer_checklist": [
      "明确结论",
      "关键数据",
      "数据出处",
      "来源链接",
      "事实与推断区分",
      "风险或反例"
    ]
  },
  "version": 2,
  "policy_name": "evidence_first_answer_protocol",
  "global_rules": [
    "结论必须由数据支撑，不能只给观点。",
    "凡是引用数据，必须明确说明数据是什么。",
    "凡是引用外部信息，必须明确说明出处名称。",
    "凡是引用外部信息，必须尽量给出可访问链接或原始来源标识。",
    "回答中必须区分事实、推断、假设、风险。",
    "当证据不足时，必须显式说明不确定性，不能伪装成确定结论。",
    "优先保证正确性、可验证性、可审计性，其次才是速度与篇幅。"
  ],
  "answer_structure": {
    "required_sections": [
      "结论",
      "核心数据",
      "数据出处",
      "分析与推断",
      "主要风险",
      "待验证点"
    ],
    "section_rules": {
      "结论": [
        "先给简明结论。",
        "不得脱离后文数据与出处单独成立。"
      ],
      "核心数据": [
        "列出支撑结论的关键数字、时间、对象、对比基准。",
        "如果无可靠数字，必须写明“暂无足够数据支持量化判断”。"
      ],
      "数据出处": [
        "每条核心数据尽量对应一个明确出处。",
        "出处至少包含：来源名称。",
        "如条件允许，再附链接、报告名、公告名、时间戳、接口名中的一种或多种。"
      ],
      "分析与推断": [
        "把基于事实得到的推断单列，不与事实混写。",
        "推断要说明依据。"
      ],
      "主要风险": [
        "至少给出1条可能推翻结论的风险因素或反例。",
        "避免单边结论。"
      ],
      "待验证点": [
        "指出还缺什么数据、公告、口径或后续观测点。"
      ]
    }
  },
  "citation_rules": {
    "require_source_name": true,
    "require_source_locator": true,
    "preferred_locator_order": [
      "direct_url",
      "official_report_title",
      "official_announcement_title",
      "api_endpoint",
      "document_date"
    ],
    "forbidden_patterns": [
      "只写“据媒体报道”但不写媒体名称",
      "只写“公开资料显示”但不写来源",
      "只给结论不给出处"
    ]
  },
  "reasoning_layers": {
    "must_tag_layers": true,
    "layer_order": [
      "事实",
      "推断",
      "假设",
      "风险"
    ],
    "layer_definitions": {
      "事实": "可由数据、公告、财报、官方页面、权威来源直接支持的内容。",
      "推断": "基于事实进行的分析判断。",
      "假设": "在证据尚不充分时作出的条件性前提。",
      "风险": "可能导致结论失效、反转或偏离的因素。"
    }
  },
  "report_output": {
    "word_enabled": true,
    "excel_enabled": true,
    "downloadable_channels": [
      "feishu",
      "qbot"
    ],
    "word_purpose": "面向终端用户的正式交付报告",
    "excel_purpose": "底层评分、证据、题库与辅助明细"
  }
}
