{
  "schema_version": 2,
  "openclaw_config_path": "~/.openclaw/openclaw.json",
  "backup_root": "~/.openclaw/backups",
  "managed_skills_root": "~/.openclaw/skills",
  "readiness_evidence_directory": "logs/dev_employee/openclaw_readonly_tool_readiness",
  "gateway_service": "openclaw-gateway.service",
  "required_auth_mode": "token",
  "baseline_project_key": "oris-final-acceptance-api",
  "public_routes": {
    "root": "/",
    "restricted": [
      "/admin",
      "/_oris-chat-shell"
    ]
  },
  "routing_skill": {
    "name": "oris-readonly-status",
    "source_directory": "skills/oris-readonly-status",
    "install_scope": "global",
    "force_replace": true
  },
  "tool_policy": {
    "required_profile": "coding",
    "profile_expansions": {
      "2026.5.19": {
        "coding": [
          "group:fs",
          "group:runtime",
          "group:web",
          "group:sessions",
          "group:memory",
          "cron",
          "image",
          "image_generate",
          "skill_workshop",
          "video_generate"
        ]
      }
    },
    "safe_builtin_probe_candidates": [
      "session_status",
      "sessions_list"
    ],
    "direct_probe_session_key": "main"
  },
  "agent_acceptance": {
    "session_prefix": "oris-readonly-acceptance",
    "turn_timeout_seconds": 240,
    "telemetry_wait_seconds": 90,
    "require_gateway_transport": true,
    "require_persisted_native_session": true,
    "turns": [
      {
        "intent": "queue_status",
        "expected_tool": "oris_queue_status",
        "message_template": "请不要根据记忆或前文推断。请使用系统提供的 ORIS 只读队列状态工具实时查询当前开发员工队列，并明确说明现在是否有任务正在运行。"
      },
      {
        "intent": "latest_task_status",
        "expected_tool": "oris_latest_task_status",
        "message_template": "请不要复用上一轮结果。请使用系统提供的 ORIS 只读最新任务状态工具实时查询最近一个任务，并概括它当前处于哪个阶段。"
      },
      {
        "intent": "task_status",
        "expected_tool": "oris_task_status",
        "message_template": "请不要根据记忆回答。请使用系统提供的 ORIS 只读指定任务状态工具实时查询任务 {task_id}，并说明下一步是什么。"
      }
    ]
  },
  "telemetry": {
    "default_path": "~/.local/state/oris/openclaw-plugin/latency.jsonl",
    "required_events": [
      "model_call_ended",
      "after_tool_call",
      "agent_end"
    ]
  },
  "evidence": {
    "directory": "logs/dev_employee/openclaw_readonly_tool_enablement",
    "commit_message_prefix": "chore(dev-employee): record automatic read-only tool acceptance"
  }
}
