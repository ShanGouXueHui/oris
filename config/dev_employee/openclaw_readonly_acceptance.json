{
  "schema_version": 5,
  "runtime": {
    "openclaw_version": "2026.5.19",
    "openclaw_config_path": "~/.openclaw/openclaw.json",
    "backup_root": "~/.openclaw/backups",
    "managed_skills_root": "~/.openclaw/skills",
    "gateway_service": "openclaw-gateway.service",
    "gateway_url": "http://127.0.0.1:18789",
    "public_url": "https://control.orisfy.com",
    "internal_ports": [18891, 18892]
  },
  "plugin": {
    "id": "oris-dev-employee",
    "version": "0.1.0",
    "private_marker": "~/.openclaw/private/oris-dev-employee-plugin-install-current.json",
    "telemetry_path": "~/.local/state/oris/openclaw-plugin/latency.jsonl"
  },
  "baseline": {
    "project_key": "oris-final-acceptance-api",
    "expected_commit": "bcb93e17ea88704548101f5e4a5c460e15a80ec7"
  },
  "readiness_evidence_directory": "logs/dev_employee/openclaw_readonly_tool_readiness",
  "public_routes": {
    "root": "/",
    "restricted": [
      "/admin",
      "/_oris-chat-shell"
    ]
  },
  "routing_skill": {
    "name": "oris-readonly-status",
    "source_directory": "skills/oris-readonly-status",
    "install_scope": "global",
    "force_replace": true
  },
  "tool_policy": {
    "approved_tools": [
      "oris_queue_status",
      "oris_task_status",
      "oris_latest_task_status"
    ],
    "required_profile": "coding",
    "profile_expansions": {
      "2026.5.19": {
        "coding": [
          "group:fs",
          "group:runtime",
          "group:web",
          "group:sessions",
          "group:memory",
          "cron",
          "image",
          "image_generate",
          "skill_workshop",
          "video_generate"
        ]
      }
    },
    "safe_builtin_probe_candidates": [
      "session_status",
      "sessions_list"
    ],
    "direct_probe_session_key": "main"
  },
  "agent_acceptance": {
    "session_prefix": "oris-readonly-acceptance",
    "turn_timeout_seconds": 240,
    "telemetry_wait_seconds": 90,
    "require_gateway_transport": true,
    "require_persisted_native_session": true,
    "turns": [
      {
        "intent": "queue_status",
        "expected_tool": "oris_queue_status",
        "message_template": "请不要根据记忆或前文推断。请使用系统提供的 ORIS 只读队列状态工具实时查询当前开发员工队列，并明确说明现在是否有任务正在运行。"
      },
      {
        "intent": "latest_task_status",
        "expected_tool": "oris_latest_task_status",
        "message_template": "请不要复用上一轮结果。请使用系统提供的 ORIS 只读最新任务状态工具实时查询最近一个任务，并概括它当前处于哪个阶段。"
      },
      {
        "intent": "task_status",
        "expected_tool": "oris_task_status",
        "message_template": "请不要根据记忆回答。请使用系统提供的 ORIS 只读指定任务状态工具实时查询任务 {task_id}，并说明下一步是什么。"
      }
    ]
  },
  "telemetry": {
    "required_events": [
      "model_call_ended",
      "after_tool_call",
      "agent_end"
    ],
    "native_support_tools": [
      {
        "name": "read",
        "max_calls": 1,
        "purpose": "load the approved routing Skill body from its native OpenClaw Skill catalog entry"
      }
    ]
  },
  "evidence": {
    "enablement": {
      "directory": "logs/dev_employee/openclaw_readonly_tool_enablement",
      "filename_prefix": "openclaw-readonly-automatic-enablement",
      "commit_message_prefix": "chore(dev-employee): record automatic read-only tool acceptance"
    },
    "effective_surface_diagnostic": {
      "directory": "logs/dev_employee/openclaw_effective_tool_surface",
      "filename_prefix": "openclaw-effective-tool-surface",
      "commit_message_prefix": "chore(dev-employee): record effective tool surface diagnostic"
    }
  }
}
