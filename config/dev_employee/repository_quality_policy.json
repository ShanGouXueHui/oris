{
  "schema_version": 2,
  "scan_roots": [
    "scripts",
    "orchestration",
    "config",
    "skills"
  ],
  "excluded_directory_names": [
    ".git",
    ".venv",
    "venv",
    "node_modules",
    "dist",
    "build",
    "__pycache__",
    "logs",
    "memory",
    "vendor",
    "dev_employee_chat_sessions",
    "dev_employee_intake_catalog",
    "dev_employee_queue",
    "dev_employee_runs",
    "dev_employee_events",
    "dev_employee_evidence",
    "dev_employee_approvals",
    "dev_employee_cancel_requests",
    "dev_employee_retry_requests",
    "dev_employee_status",
    "task_runs"
  ],
  "excluded_path_prefixes": [
    "orchestration/dev_employee_chat_sessions",
    "orchestration/dev_employee_intake_catalog",
    "orchestration/dev_employee_queue",
    "orchestration/dev_employee_runs",
    "orchestration/dev_employee_events",
    "orchestration/dev_employee_evidence",
    "orchestration/dev_employee_approvals",
    "orchestration/dev_employee_cancel_requests",
    "orchestration/dev_employee_retry_requests",
    "orchestration/dev_employee_status",
    "orchestration/task_runs"
  ],
  "worktree_runtime_path_prefixes": [
    "logs",
    "memory/dev_employee",
    "orchestration/dev_employee_events",
    "orchestration/task_runs",
    "vendor/skill_candidates"
  ],
  "excluded_file_names": [
    "generic_insight_enqueue_state.json",
    "provider_health_snapshot.json",
    "provider_scoreboard.json"
  ],
  "exclude_timestamped_json": true,
  "source_extensions": [
    ".py",
    ".sh",
    ".ts",
    ".tsx",
    ".js",
    ".mjs",
    ".cjs",
    ".json",
    ".yaml",
    ".yml",
    ".toml",
    ".md"
  ],
  "code_extensions": [
    ".py",
    ".sh",
    ".ts",
    ".tsx",
    ".js",
    ".mjs",
    ".cjs"
  ],
  "authoritative_literal_files": [
    "orchestration/project_registry.json",
    "orchestration/openclaw_plugins/oris-dev-employee/openclaw.plugin.json",
    "config/dev_employee/openclaw_readonly_acceptance.json",
    "config/dev_employee/repository_quality_policy.json",
    "config/dev_employee/runtime_settings.json"
  ],
  "detectors": [
    "duplicate_symbol",
    "duplicate_json_key",
    "plaintext_secret",
    "absolute_host_path",
    "environment_loopback_port",
    "public_oris_domain",
    "embedded_commit_sha",
    "embedded_commercial_task_id",
    "acceptance_project_name",
    "forbidden_set_e",
    "large_file"
  ],
  "environment_ports": [
    18789,
    18891,
    18892,
    18893
  ],
  "public_domains": [
    "control.orisfy.com"
  ],
  "acceptance_project_names": [
    "oris-final-acceptance-api"
  ],
  "large_file_line_limits": {
    ".py": 300,
    ".sh": 220,
    ".ts": 350,
    ".tsx": 350,
    ".js": 300,
    ".mjs": 300,
    ".cjs": 300
  },
  "evidence_directory": "logs/dev_employee/repository_quality_scan"
}
