{
  "version": 3,
  "driver": "postgresql",
  "schema": "insight",
  "sslmode": "disable",
  "artifact_storage_root": "outputs/artifacts",
  "word_enabled": true,
  "excel_enabled": true,
  "ppt_enabled": false,
  "downloadable_channels": [
    "feishu",
    "qbot"
  ],
  "governance": {
    "config_first": true,
    "db_first_for_variable_rules": true,
    "no_business_constants_in_scripts": true,
    "plaintext_secrets_forbidden": true,
    "single_authoritative_db_config": true
  },
  "db": {
    "host": "127.0.0.1",
    "port": 5432,
    "dbname": "oris_insight",
    "user": "oris_app",
    "password_secret_ref": "secrets_json:~/.openclaw/secrets.json::postgres.oris_insight.password"
  },
  "storage_engine": "postgres",
  "config_version": 4
}
