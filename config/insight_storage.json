{
  "version": 1,
  "driver": "postgresql",
  "database": "oris_insight",
  "schema": "insight",
  "host": "127.0.0.1",
  "port": 5432,
  "user": "oris_app",
  "password_secret_ref": "secrets_json:/home/admin/.openclaw/secrets.json::postgres.oris_insight.password",
  "sslmode": "disable",
  "artifact_storage_root": "outputs/artifacts",
  "word_enabled": true,
  "excel_enabled": true,
  "ppt_enabled": false,
  "downloadable_channels": [
    "feishu",
    "qbot"
  ],
  "governance": {
    "config_first": true,
    "db_first_for_variable_rules": true,
    "no_business_constants_in_scripts": true
  }
}
