{
  "schema_version": "2026-05-20.free_mesh_api.v1",
  "host": "127.0.0.1",
  "port": 8789,
  "logical_models": {
    "oris/free-auto": "primary_general",
    "oris/free-coding": "coding",
    "oris/free-report": "report_generation",
    "oris/free-fallback": "free_fallback",
    "oris/free-cn": "cn_candidate_pool"
  },
  "default_model": "oris/free-auto",
  "auth": {
    "secrets_path": "~/.openclaw/secrets.json",
    "secret_json_path": ["services", "oris_api", "bearerToken"],
    "header": "Authorization: Bearer <token>",
    "fallback_header": "X-ORIS-API-Key"
  },
  "routing_source": {
    "infer_script": "scripts/oris_infer.py",
    "runtime_plan": "orchestration/runtime_plan.json"
  },
  "safety": {
    "free_mesh_only": true,
    "do_not_bind_openclaw_to_real_model": true,
    "real_provider_selection_owned_by_oris": true
  }
}
