  "unit_display": {
    "percent": {
      "kind": "suffix",
      "suffix": "%"
    },
    "USD_billion": {
      "kind": "multiply_suffix",
      "multiplier": 10,
      "suffix": "亿美元"
    },
    "USD_million": {
      "kind": "divide_suffix",
      "divisor": 100,
      "suffix": "亿美元"
    },
    "RMB_billion": {
      "kind": "multiply_prefix_suffix",
      "multiplier": 10,
      "prefix": "人民币",
      "suffix": "亿元"
    },
    "RMB_million": {
      "kind": "divide_prefix_suffix",
      "divisor": 100,
      "prefix": "人民币",
      "suffix": "亿元"
    },
    "million_accounts": {
      "kind": "suffix",
      "suffix": "百万账户"
    },
    "billion_users": {
      "kind": "multiply_suffix",
      "multiplier": 10,
      "suffix": "亿用户"
    },
    "steps": {
      "kind": "suffix",
      "suffix": "步",
      "decimals": 0
    },
    "B_params_class": {
      "kind": "suffix",
      "suffix": "B参数级",
      "decimals": 0
    },
    "tokens_per_second": {
      "kind": "suffix",
      "suffix": " tokens/s"
    },
    "tokens_per_1k": {
      "kind": "prefix_suffix",
      "prefix": "",
      "suffix": " / 1K tokens"
    },
    "tokens_per_million": {
      "kind": "prefix_suffix",
      "prefix": "",
      "suffix": " / 1M tokens"
    },
    "RMB_per_million_tokens": {
      "kind": "prefix_suffix",
      "prefix": "人民币",
      "suffix": "元/百万tokens"
    },
    "USD_per_million_tokens": {
      "kind": "prefix_suffix",
      "prefix": "$",
      "suffix": "/百万tokens"
    }
  },
