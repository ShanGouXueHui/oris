{
  "version": 2,
  "paths": {
    "report_download_server_log": "orchestration/report_download_server_log.jsonl"
  },
  "report_delivery": {
    "public_download_base_url": "https://control.orisfy.com/oris-download",
    "download_path_prefix": "/download",
    "default_link_ttl_hours": 24,
    "sensitive_link_ttl_hours": 2,
    "package_link_ttl_hours": 24,
    "default_max_downloads": 3,
    "package_max_downloads": 2,
    "json_manifest_downloadable": false,
    "allowed_public_extensions": [
      ".docx",
      ".xlsx",
      ".zip",
      ".pdf",
      ".pptx"
    ],
    "downloadable_channels": [
      "feishu",
      "qbot"
    ],
    "download_security_version": 2
  },
  "delivery": {
    "task_table": "insight.delivery_task",
    "pending_status": "pending",
    "sent_status": "sent",
    "failed_status": "failed",
    "channel_type_map": {
      "feishu": "feishu",
      "qbot": "qbot"
    },
    "channel_targets": {
      "feishu": {
        "target_type": "chat_id",
        "default_target": "oc_2088cbc62e2aa06533848ec7b7b06415"
      },
      "qbot": {
        "target_type": "webhook",
        "default_target": null
      }
    },
    "execution_channels": [
      "feishu"
    ],
    "disabled_channels": {
      "qbot": {
        "enabled": false,
        "reason": "qq_open_platform_approval_pending",
        "keep_tasks_pending": true
      }
    }
  },
  "channels": {
    "feishu": {
      "mode": "feishu_messages_api",
      "receive_id_type": "chat_id",
      "default_receive_id": "oc_2088cbc62e2aa06533848ec7b7b06415",
      "execute_enabled": true
    },
    "qbot": {
      "mode": "generic_webhook",
      "webhook_url_env": "QBOT_WEBHOOK_URL",
      "default_target": null,
      "execute_enabled": false,
      "dry_run_without_credentials": true
    }
  }
}
