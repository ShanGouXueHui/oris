{
  "version": 1,
  "default_output_schema_version": "v1",
  "answer_protocol": {
    "layers": [
      "facts",
      "inferences",
      "hypotheses",
      "risks"
    ],
    "required_sections": [
      "conclusion",
      "core_data",
      "sources",
      "analysis",
      "risks",
      "next_steps"
    ]
